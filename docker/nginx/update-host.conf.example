server {
    listen 80;
    server_name updates.your-domain.com;

    add_header X-Content-Type-Options nosniff always;
    add_header X-Frame-Options DENY always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name updates.your-domain.com;

    ssl_certificate /etc/letsencrypt/live/updates.your-domain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/updates.your-domain.com/privkey.pem;

    add_header X-Content-Type-Options nosniff always;
    add_header X-Frame-Options DENY always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;

    root /var/www/thokan-updates;
    autoindex off;
    charset utf-8;

    # Force JSON content type for manifest files
    location ~* \.json$ {
        default_type application/json;
        add_header Cache-Control "no-cache, no-store, must-revalidate" always;
        try_files $uri =404;
    }

    # Package artifacts (.zip/.tar/.tar.gz/.tgz)
    location ~* \.(zip|tar|tar\.gz|tgz)$ {
        add_header Cache-Control "public, max-age=300" always;
        try_files $uri =404;
    }

    # Optional health endpoint for monitoring
    location = /health {
        default_type application/json;
        return 200 '{"status":"ok","service":"thokan-update-host"}';
    }

    # Deny everything else by default (tight static host)
    location / {
        try_files $uri =404;
    }
}
